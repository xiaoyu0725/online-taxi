<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taxi.serviceDriverUser.mapper.DriverUserMapper">

    <select id="selectDriverUserCountByCityCode" parameterType="java.lang.String" resultType="java.lang.Integer">
        select count(*) from v_city_driver_user_word_status_ where city_code = #{cityCode}
    </select>

</mapper>
